# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=${{PORT}}

# Required app role configuration
AppRoles=worker:categorisation

# Database
# Prefer the Railway-managed value from `pnpm railway:patch`.
ConnectionStrings__DefaultConnection=${{Postgres.DATABASE_URL}}

# Auth/data protection storage
AuthStateStore__Provider=Redis

# JWT
Jwt__Issuer=https://api.example.com
Jwt__Audience=https://api.example.com
Jwt__Key=replace-with-a-long-random-production-secret

# S3-compatible storage
# Prefer the Railway-managed values from `pnpm railway:patch`.
S3__ServiceUrl=${{Bucket.ENDPOINT}}
S3__AccessKey=${{Bucket.ACCESS_KEY_ID}}
S3__SecretKey=${{Bucket.SECRET_ACCESS_KEY}}
S3__BucketName=${{Bucket.BUCKET}}
S3__Region=${{Bucket.REGION}}

# Redis
# Prefer the Railway-managed value from `pnpm railway:patch`.
ConnectionStrings__Redis=${{Redis.REDIS_URL}}

# OpenAI
OpenAI__ApiKey=replace-with-your-production-openai-api-key
OpenAI__Model=gpt-4o-mini

# Allowed frontend origins
CORS_ORIGINS=https://app.example.com,https://api.example.com

# Background processing
UPLOAD_CATEGORIZATION_BATCH_SIZE=50
RetentionCleanup__RetentionDays=30

# OpenTelemetry
OTEL_EXPORTER_ENDPOINT=https://api.axiom.co/v1/traces
OTEL_EXPORTER_LOGS_ENDPOINT=https://api.axiom.co/v1/logs
OTEL_EXPORTER_API_KEY=replace-with-your-axiom-api-key
OTEL_AXIOM_DATASET=meal-prep-prod
