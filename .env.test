# Test environment for Api.Tests
# This file is the single source of truth for test env vars.

# Database (use docker compose service hostnames)
ConnectionStrings__DefaultConnection="Host=db;Port=5432;Database=postgres;Username=root;Password=password;Include Error Detail=true"

# Redis
ConnectionStrings__Redis=redis:6379

# S3 / MinIO
S3__ServiceUrl=http://minio:9000
S3__AccessKey=minio
S3__SecretKey=123456789
S3__BucketName=meal-prep-autotest
S3__Region=eu-west-1

# OpenAI (mocked in tests, but required by startup)
OpenAI__ApiKey=test-key

# Logging (reduce test noise)
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft=Warning
Logging__LogLevel__System=Warning

# Disable OpenTelemetry exporters during tests
Test__DisableOpenTelemetry=true
