# Required app role configuration
AppRoles=worker:categorisation

# Database
ConnectionStrings__DefaultConnection="Host=localhost;Port=5432;Database=meal_prep_dev;Username=root;Password=password"

# Auth/data protection storage
AuthStateStore__Provider=Redis

# JWT
Jwt__Issuer=api.meal-prep.example.com
Jwt__Audience=api.meal-prep.example.com
Jwt__Key=changeme

# S3 Storage (MinIO)
S3__ServiceUrl=http://localhost:9000
S3__AccessKey=minio
S3__SecretKey=123456789
S3__BucketName=meal-prep-dev
S3__Region=eu-west-1

# S3 Storage (AWS)
# S3__ServiceUrl=''
# S3__AccessKey=''
# S3__SecretKey=''
# S3__BucketName=''
# S3__Region=''

# Redis
ConnectionStrings__Redis=127.0.0.1:6379

# OpenAI-compatible API (OpenRouter default; use api.openai.com/v1 + OpenAI key if preferred)
OpenAI__ApiKey=changeme
OpenAI__BaseUrl=https://openrouter.ai/api/v1
OpenAI__Model=openai/gpt-4o-mini

CORS_ORIGINS=http://localhost:8080,http://localhost:5000,http://127.0.0.1:5500,http://localho.st,null,https://meal-prep-ui.pages.dev,https://api.meal-prep.example.com

# Background processing
UPLOAD_CATEGORIZATION_BATCH_SIZE=50
RetentionCleanup__RetentionDays=7

# OpenTelemetry
OTEL_ENABLED=false
OTEL_ENABLE_CONSOLE_EXPORTER=false
# OTEL_EXPORTER_ENDPOINT=https://api.axiom.co/v1/traces
# OTEL_EXPORTER_LOGS_ENDPOINT=https://api.axiom.co/v1/logs
OTEL_EXPORTER_API_KEY=
OTEL_AXIOM_DATASET=
