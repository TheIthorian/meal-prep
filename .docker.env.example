HOST=0.0.0.0
PORT=7210

#ASPNETCORE_HTTPS_PORTS=5000
#ASPNETCORE_HTTP_PORTS=5001

# Logging
Logging__LogLevel__Default=Warning
Logging__LogLevel__Microsoft__AspNetCore=Warning

# Required app role configuration
AppRoles=worker:categorisation

# Database
ConnectionStrings__DefaultConnection="Host=db;Port=5432;Database=meal_prep;Username=root;Password=password"

# Auth/data protection storage
AuthStateStore__Provider=Redis

# JWT
Jwt__Issuer=meal-prep.local
Jwt__Audience=meal-prep.local
Jwt__Key=changeme

# S3 Storage (MinIO)
S3__ServiceUrl=http://minio:9000
S3__AccessKey=minio
S3__SecretKey=123456789
S3__BucketName=meal-prep
S3__Region=eu-west-1

# S3 Storage (AWS)
# S3__ServiceUrl=''
# S3__AccessKey=''
# S3__SecretKey=''
# S3__BucketName=''
# S3__Region=''

# Redis
ConnectionStrings__Redis=redis:6379

# OpenAI-compatible API
OpenAI__ApiKey=changeme
OpenAI__Model=gpt-4o-mini

CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5001

# Background processing
UPLOAD_CATEGORIZATION_BATCH_SIZE=50
RetentionCleanup__RetentionDays=7

# OpenTelemetry (disabled by default for local use)
OTEL_ENABLED=false
OTEL_ENABLE_CONSOLE_EXPORTER=false
